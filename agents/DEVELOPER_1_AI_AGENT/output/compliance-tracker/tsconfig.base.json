{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "paths": {
      "@compliancetrack/db": [
        "./packages/db/src"
      ],
      "@compliancetrack/types": [
        "./packages/types/src"
      ],
      "@compliancetrack/api-client": [
        "./packages/api-client/src"
      ],
      "@compliancetrack/ui": [
        "./packages/ui/src"
      ],
      "@compliancetrack/config": [
        "./packages/config/src"
      ]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    ".next",
    ".expo"
  ]
}