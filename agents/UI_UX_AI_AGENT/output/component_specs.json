{
  "meta": {
    "project": "ComplianceTrack",
    "version": "1.0.0",
    "task_id": "T-M2",
    "base_library": "shadcn/ui",
    "implementation_note": "All components accept className prop for Tailwind overrides"
  },
  "components": {
    "Button": {
      "variants": {
        "primary": {
          "bg": "#F5820A",
          "color": "#FFFFFF",
          "border": "none",
          "shadow": "0 4px 12px rgba(245,130,10,0.25)",
          "hover": { "bg": "#E0730A", "transform": "translateY(-1px)" },
          "disabled": { "opacity": 0.6, "cursor": "not-allowed", "transform": "none" }
        },
        "secondary": {
          "bg": "transparent",
          "color": "#4A5568",
          "border": "1.5px solid #CBD5E1",
          "hover": { "bg": "#F0F4F8", "borderColor": "#CBD5E1" }
        },
        "teal": {
          "bg": "#0E7C6E",
          "color": "#FFFFFF",
          "hover": { "bg": "#0A6B5E" }
        },
        "ghost": {
          "bg": "rgba(255,255,255,0.07)",
          "color": "rgba(255,255,255,0.75)",
          "border": "1px solid rgba(255,255,255,0.12)",
          "hover": { "bg": "rgba(255,255,255,0.12)", "color": "#FFFFFF" }
        },
        "danger": {
          "bg": "transparent",
          "color": "#C0392B",
          "border": "1.5px solid #E2E8F0",
          "hover": { "bg": "#FDECEB", "borderColor": "#C0392B" }
        }
      },
      "sizes": {
        "sm": { "padding": "6px 13px", "fontSize": "11px", "borderRadius": "10px", "fontWeight": 700 },
        "md": { "padding": "10px 20px", "fontSize": "13px", "borderRadius": "10px", "fontWeight": 600 },
        "lg": { "padding": "13px 24px", "fontSize": "15px", "borderRadius": "10px", "fontWeight": 700 }
      },
      "states": ["default", "hover", "focus", "active", "disabled", "loading"],
      "loading": { "spinnerSize": "16px", "opacity": 0.8 }
    },
    "Input": {
      "default": {
        "padding": "11px 14px",
        "border": "1.5px solid #CBD5E1",
        "borderRadius": "10px",
        "fontSize": "14px",
        "bg": "#FFFFFF",
        "color": "#1C2B3A"
      },
      "focus": { "borderColor": "#F5820A", "boxShadow": "0 0 0 3px rgba(245,130,10,0.1)" },
      "error": { "borderColor": "#C0392B", "boxShadow": "0 0 0 3px rgba(192,57,43,0.08)" },
      "disabled": { "bg": "#F0F4F8", "opacity": 0.7, "cursor": "not-allowed" }
    },
    "Select": {
      "inherits": "Input",
      "chevron": { "size": "14px", "color": "#718096" }
    },
    "Textarea": {
      "inherits": "Input",
      "minHeight": "60px",
      "resize": "vertical"
    },
    "SearchInput": {
      "inherits": "Input",
      "paddingLeft": "32px",
      "iconSize": "14px",
      "iconColor": "#718096",
      "defaultBg": "#F0F4F8",
      "focusBg": "#FFFFFF",
      "minWidth": "200px"
    },
    "Badge": {
      "variants": {
        "default": { "padding": "2px 8px", "borderRadius": "6px", "fontSize": "10px", "fontWeight": 700 },
        "pill": { "padding": "3px 10px", "borderRadius": "9999px", "fontSize": "10px", "fontWeight": 700 },
        "sidebar": { "padding": "2px 6px", "borderRadius": "9999px", "fontSize": "9px", "minWidth": "18px", "textAlign": "center" }
      },
      "semanticColors": {
        "overdue": { "bg": "#FDECEB", "text": "#C0392B" },
        "warning": { "bg": "#FEF3E2", "text": "#F5820A" },
        "safe": { "bg": "#E6F4F2", "text": "#0E7C6E" },
        "success": { "bg": "#F0FDF4", "text": "#16A34A" },
        "draft": { "bg": "#F5F3FF", "text": "#7C3AED", "border": "1px dashed #7C3AED" }
      }
    },
    "Card": {
      "default": {
        "bg": "#FFFDF9",
        "border": "1px solid #E2E8F0",
        "borderRadius": "20px",
        "shadow": "0 1px 3px rgba(0,0,0,0.07)",
        "overflow": "hidden"
      },
      "table": { "borderRadius": "20px", "padding": 0 },
      "modal": { "borderRadius": "28px", "shadow": "0 16px 48px rgba(0,0,0,0.12)" }
    },
    "Table": {
      "header": {
        "bg": "#F0F4F8",
        "fontSize": "10px",
        "fontWeight": 700,
        "textTransform": "uppercase",
        "letterSpacing": "0.08em",
        "color": "#718096",
        "padding": "11px 14px",
        "borderBottom": "2px solid #E2E8F0"
      },
      "cell": { "padding": "13px 14px", "fontSize": "13px", "borderBottom": "1px solid #E2E8F0" },
      "rowHover": { "bg": "#FAFBFF" },
      "rowVariants": {
        "overdue": { "bg": "rgba(192,57,43,0.03)" },
        "under30": { "bg": "rgba(245,130,10,0.03)" },
        "draft": { "bg": "rgba(99,102,241,0.03)" },
        "notApplicable": { "opacity": 0.55 }
      }
    },
    "Sidebar": {
      "width": "220px",
      "bg": "#FFFDF9",
      "borderRight": "1px solid #E2E8F0",
      "item": {
        "padding": "9px 20px",
        "fontSize": "13px",
        "fontWeight": 500,
        "color": "#4A5568",
        "borderLeft": "3px solid transparent",
        "iconSize": "16px",
        "gap": "9px"
      },
      "itemHover": { "bg": "#F0F4F8", "color": "#1C2B3A" },
      "itemActive": { "bg": "#FEF3E2", "color": "#F5820A", "fontWeight": 700, "borderLeftColor": "#F5820A" },
      "sectionLabel": { "fontSize": "9px", "fontWeight": 800, "letterSpacing": "0.1em", "color": "#718096", "padding": "8px 20px 6px" }
    },
    "NavBar": {
      "height": "60px",
      "bg": "#1C2B3A",
      "padding": "0 24px",
      "logoMark": { "size": "34px", "borderRadius": "9px", "bg": "#F5820A" },
      "sticky": true,
      "zIndex": 60
    },
    "HealthRibbon": {
      "height": "48px",
      "bg": "#FFFDF9",
      "borderBottom": "1px solid #E2E8F0",
      "padding": "12px 24px",
      "chipPadding": "7px 14px",
      "chipBorderRadius": "9999px",
      "chipFontSize": "12px",
      "chipFontWeight": 700,
      "dotSize": "8px"
    },
    "Sheet": {
      "detailPanel": {
        "width": "480px",
        "maxWidth": "100vw",
        "headerBg": "linear-gradient(135deg, #1C2B3A, #2D3F52)",
        "headerTitleColor": "#FFFFFF",
        "tabActiveColor": "#F5820A",
        "tabActiveBorder": "2px solid #F5820A",
        "footerBg": "#FAFBFC",
        "footerPadding": "12px 22px"
      }
    },
    "Modal": {
      "backdrop": { "bg": "rgba(28,43,58,0.55)", "blur": "6px" },
      "content": { "maxWidth": "640px", "padding": "28px", "borderRadius": "28px" },
      "footer": { "bg": "#FAFBFC", "padding": "16px 28px", "borderTop": "1px solid #E2E8F0" }
    },
    "Tabs": {
      "segmented": {
        "containerBg": "#F0F4F8",
        "containerPadding": "4px",
        "containerRadius": "10px",
        "tabPadding": "8px",
        "tabRadius": "6px",
        "activeBg": "#FFFFFF",
        "activeShadow": "0 1px 3px rgba(0,0,0,0.07)"
      },
      "underline": {
        "tabPadding": "10px 8px",
        "fontSize": "12px",
        "fontWeight": 600,
        "activeColor": "#F5820A",
        "activeBorderBottom": "2px solid #F5820A"
      }
    },
    "PasscodeInput": {
      "dotSize": "52px",
      "dotGap": "16px",
      "dotBorderRadius": "10px",
      "numpadGap": "10px",
      "numpadButtonHeight": "52px",
      "filledBg": "#1C2B3A",
      "activeBorder": "#F5820A",
      "activeRing": "0 0 0 3px rgba(245,130,10,0.15)"
    },
    "Avatar": {
      "sizes": { "sm": "28px", "md": "34px", "lg": "52px" },
      "defaultBg": "#F5820A",
      "color": "#FFFFFF",
      "fontWeight": 800,
      "border": "2px solid rgba(255,255,255,0.2)"
    },
    "Toast": {
      "position": "fixed bottom 100px center",
      "bg": "#1C2B3A",
      "color": "#FFFFFF",
      "padding": "10px 22px",
      "borderRadius": "9999px",
      "fontSize": "12px",
      "fontWeight": 600,
      "shadow": "0 8px 24px rgba(0,0,0,0.2)",
      "animation": "fade slide up 300ms"
    },
    "FAB": {
      "size": "54px",
      "bg": "linear-gradient(135deg, #F5820A, #E0730A)",
      "shadow": "0 6px 24px rgba(245,130,10,0.45)",
      "iconSize": "24px",
      "menuItemRadius": "9999px",
      "menuItemHover": { "bg": "#F5820A", "color": "#FFFFFF", "transform": "translateX(-4px)" }
    },
    "Alert": {
      "error": { "bg": "#FDECEB", "border": "1px solid #E8A39D", "color": "#C0392B", "padding": "10px 14px", "borderRadius": "10px" },
      "success": { "bg": "#E6F4F2", "border": "1px solid #7ECDC5", "color": "#0E7C6E" }
    },
    "FileUpload": {
      "border": "2px dashed #CBD5E1",
      "borderRadius": "16px",
      "padding": "20px",
      "bg": "#FAFBFC",
      "hover": { "borderColor": "#F5820A", "bg": "#FEF3E2" }
    }
  }
}
