{
  "meta": {
    "project": "ComplianceTrack",
    "version": "1.0.0",
    "created_by": "UI_UX_AI_AGENT",
    "task_id": "T-M2",
    "source_reference": "specs/compliance_tracker_v3.html",
    "tailwind_prefix": "ct"
  },
  "colors": {
    "brand": {
      "cream": { "hex": "#FFFDF9", "usage": "Primary surface, cards, sidebar background" },
      "navy": { "hex": "#1C2B3A", "usage": "Primary text, nav bar, auth header" },
      "navy2": { "hex": "#2D3F52", "usage": "Gradient mid-tone, secondary dark surfaces" },
      "navy3": { "hex": "#3D5269", "usage": "Tertiary dark accent" },
      "saffron": { "hex": "#F5820A", "usage": "Primary CTA, active nav, focus rings, logo mark" },
      "saffronHover": { "hex": "#E0730A", "usage": "Button hover state" },
      "teal": { "hex": "#0E7C6E", "usage": "Success/safe pendency, secondary CTA" },
      "tealHover": { "hex": "#0A6B5E", "usage": "Teal button hover" }
    },
    "semantic": {
      "success": { "hex": "#16A34A", "light": "#F0FDF4", "border": "#86EFAC" },
      "warning": { "hex": "#E67E22", "light": "#FEF9EC", "border": "#F5CBA7" },
      "error": { "hex": "#C0392B", "light": "#FDECEB", "medium": "#E8A39D" },
      "info": { "hex": "#2563EB", "light": "#EFF6FF", "border": "#BFDBFE" },
      "draft": { "hex": "#7C3AED", "light": "#F5F3FF" }
    },
    "neutral": {
      "cloud": { "hex": "#F0F4F8", "usage": "Page background, table header, input bg" },
      "cloud2": { "hex": "#E8EEF5", "usage": "Secondary neutral bg" },
      "slate": { "hex": "#4A5568", "usage": "Secondary body text" },
      "muted": { "hex": "#718096", "usage": "Labels, placeholders, meta text" },
      "border": { "hex": "#E2E8F0", "usage": "Default borders" },
      "border2": { "hex": "#CBD5E1", "usage": "Input borders, stronger dividers" },
      "white": { "hex": "#FFFFFF", "usage": "Input backgrounds, modal surfaces" },
      "rowHover": { "hex": "#FAFBFF", "usage": "Table row hover" }
    },
    "pendency": {
      "overdue": { "bg": "#FDECEB", "text": "#C0392B", "border": "#E8A39D" },
      "under30": { "bg": "#FEF3E2", "text": "#F5820A", "border": "#FAC88A" },
      "under60": { "bg": "#FEF9EC", "text": "#E67E22", "border": "#F5CBA7" },
      "safe": { "bg": "#E6F4F2", "text": "#0E7C6E", "border": "#7ECDC5" },
      "done": { "bg": "#F0FDF4", "text": "#16A34A", "border": "#86EFAC" }
    }
  },
  "typography": {
    "fontFamilies": {
      "heading": "'DM Serif Display', Georgia, serif",
      "body": "'Inter', system-ui, sans-serif"
    },
    "scale": {
      "display": { "fontFamily": "heading", "size": "26px", "weight": 400, "lineHeight": 1.2, "letterSpacing": "-0.01em" },
      "h1": { "fontFamily": "heading", "size": "24px", "weight": 400, "lineHeight": 1.25 },
      "h2": { "fontFamily": "heading", "size": "22px", "weight": 400, "lineHeight": 1.3 },
      "h3": { "fontFamily": "heading", "size": "18px", "weight": 400, "lineHeight": 1.35 },
      "h4": { "fontFamily": "heading", "size": "17px", "weight": 400, "lineHeight": 1.35 },
      "bodyLg": { "fontFamily": "body", "size": "15px", "weight": 400, "lineHeight": 1.5 },
      "body": { "fontFamily": "body", "size": "14px", "weight": 400, "lineHeight": 1.5 },
      "bodySm": { "fontFamily": "body", "size": "13px", "weight": 400, "lineHeight": 1.5 },
      "caption": { "fontFamily": "body", "size": "12px", "weight": 500, "lineHeight": 1.4 },
      "label": { "fontFamily": "body", "size": "11px", "weight": 700, "lineHeight": 1.3, "textTransform": "uppercase", "letterSpacing": "0.07em" },
      "micro": { "fontFamily": "body", "size": "10px", "weight": 700, "lineHeight": 1.2, "textTransform": "uppercase", "letterSpacing": "0.08em" },
      "wordmark": { "fontFamily": "body", "size": "16px", "weight": 800, "letterSpacing": "-0.01em" }
    }
  },
  "spacing": {
    "baseUnit": "4px",
    "scale": {
      "0": "0",
      "1": "4px",
      "2": "8px",
      "3": "12px",
      "4": "16px",
      "5": "20px",
      "6": "24px",
      "7": "28px",
      "8": "32px",
      "9": "36px",
      "10": "40px",
      "12": "48px",
      "14": "56px",
      "16": "64px"
    },
    "layout": {
      "navHeight": "60px",
      "healthRibbonHeight": "48px",
      "sidebarWidth": "220px",
      "sidebarCollapsedWidth": "64px",
      "detailPanelWidth": "480px",
      "pagePadding": "24px",
      "cardPadding": "16px",
      "modalPadding": "28px",
      "authCardWidth": "440px"
    }
  },
  "borderRadius": {
    "sm": "6px",
    "md": "10px",
    "lg": "16px",
    "xl": "20px",
    "2xl": "28px",
    "full": "9999px"
  },
  "shadows": {
    "sm": "0 1px 3px rgba(0,0,0,0.07)",
    "md": "0 4px 16px rgba(0,0,0,0.08)",
    "lg": "0 16px 48px rgba(0,0,0,0.12)",
    "nav": "0 2px 8px rgba(0,0,0,0.15)",
    "saffronButton": "0 4px 16px rgba(245,130,10,0.3)",
    "saffronFab": "0 6px 24px rgba(245,130,10,0.45)",
    "toast": "0 8px 24px rgba(0,0,0,0.2)",
    "focusRing": "0 0 0 3px rgba(245,130,10,0.1)"
  },
  "breakpoints": {
    "mobile": { "min": 0, "max": 767, "columns": 4, "gutter": "16px", "margin": "16px" },
    "tablet": { "min": 768, "max": 1023, "columns": 8, "gutter": "20px", "margin": "24px" },
    "desktop": { "min": 1024, "max": 1279, "columns": 12, "gutter": "24px", "margin": "24px" },
    "wide": { "min": 1280, "max": null, "columns": 12, "gutter": "24px", "margin": "32px" }
  },
  "motion": {
    "durationFast": "120ms",
    "durationDefault": "150ms",
    "durationSlow": "300ms",
    "easing": "cubic-bezier(0.4, 0, 0.2, 1)",
    "hoverLift": "translateY(-1px)",
    "activeScale": "scale(0.96)"
  },
  "zIndex": {
    "base": 0,
    "sticky": 60,
    "dropdown": 100,
    "modalBackdrop": 200,
    "modal": 250,
    "detailPanel": 300,
    "authOverlay": 500,
    "toast": 9999
  }
}
