{
  "expo": {
    "name": "ComplianceTrack",
    "slug": "compliance-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": { "resizeMode": "contain", "backgroundColor": "#2563EB" },
    "assetBundlePatterns": ["**/*"],
    "ios": { "supportsTablet": true, "bundleIdentifier": "com.compliancetrack.app" },
    "android": { "adaptiveIcon": { "backgroundColor": "#2563EB" }, "package": "com.compliancetrack.app" },
    "web": { "bundler": "metro" },
    "plugins": ["expo-router"]
  }
}