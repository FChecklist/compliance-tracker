generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/* ─── Enums ─── */

enum UserRole {
  admin
  manager
  member
  viewer
}

enum ComplianceStatus {
  pending
  in_progress
  completed
  overdue
  not_applicable
  draft
}

enum Priority {
  low
  medium
  high
  critical
}

enum ComplianceType {
  GST
  TDS
  MCA
  PF
  ESIC
  INCOME_TAX
  ROC
  LABOUR
  ENVIRONMENTAL
  OTHER
}

enum NotificationType {
  deadline_reminder
  assignment
  status_change
  comment
  system
  mention
}

enum AuditAction {
  create
  update
  delete
  status_change
  assign
  reassign
  login
  logout
  export
  invite
}

/* ─── Models ─── */

model Organisation {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  plan      String   @default("free")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users         User[]
  departments   Department[]
  compliance    ComplianceItem[]
}

model Department {
  id          String       @id @default(cuid())
  name        String
  description String?
  orgId       String
  org         Organisation @relation(fields: [orgId], references: [id])
  headId      String?       @unique
  head        User?        @relation("DeptHead", fields: [headId], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  compliance  ComplianceItem[]
  users       User[]
}

model User {
  id           String         @id @default(cuid())
  name         String
  email        String         @unique
  passwordHash String
  role         UserRole       @default(member)
  avatarUrl    String?
  isActive     Boolean        @default(true)
  lastLoginAt  DateTime?
  orgId        String?
  org          Organisation?  @relation(fields: [orgId], references: [id])
  departmentId String?
  department   Department?    @relation(fields: [departmentId], references: [id])
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  assignedCompliance  ComplianceItem[]  @relation("AssignedTo")
  auditPointAssignments AuditPoint[]     @relation("AuditAssignee")
  headOfDept         Department?       @relation("DeptHead")
  auditLogs          AuditLog[]
  comments           Comment[]
  uploadedDocuments  Document[]

  @@index([orgId])
  @@index([departmentId])
}

model ComplianceItem {
  id             String           @id @default(cuid())
  title          String
  description    String?
  complianceType ComplianceType
  status         ComplianceStatus @default(pending)
  priority       Priority         @default(medium)
  dueDate        DateTime
  completedAt    DateTime?
  departmentId   String
  department     Department       @relation(fields: [departmentId], references: [id])
  assignedToId   String?
  assignedTo     User?            @relation("AssignedTo", fields: [assignedToId], references: [id])
  orgId          String
  org            Organisation     @relation(fields: [orgId], references: [id])
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  auditPoints    AuditPoint[]
  documents      Document[]
  comments       Comment[]

  @@index([status])
  @@index([dueDate])
  @@index([departmentId])
  @@index([orgId])
  @@index([assignedToId])
}

model AuditPoint {
  id               String           @id @default(cuid())
  title            String
  description      String?
  status           ComplianceStatus @default(pending)
  dueDate          DateTime?
  completedAt      DateTime?
  complianceItemId String
  complianceItem   ComplianceItem   @relation(fields: [complianceItemId], references: [id], onDelete: Cascade)
  assignedToId     String?
  assignedTo       User?            @relation("AuditAssignee", fields: [assignedToId], references: [id])
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([complianceItemId])
}

model Document {
  id               String         @id @default(cuid())
  name             String
  fileUrl          String
  fileType         String?
  fileSize         Int?
  complianceItemId String
  complianceItem   ComplianceItem @relation(fields: [complianceItemId], references: [id], onDelete: Cascade)
  uploadedById     String
  uploadedBy       User           @relation(fields: [uploadedById], references: [id])
  createdAt        DateTime       @default(now())

  @@index([complianceItemId])
}

model Comment {
  id               String         @id @default(cuid())
  content          String
  entityId         String
  entityType       String         @default("compliance")
  authorId         String
  author           User           @relation(fields: [authorId], references: [id])
  complianceItemId String?
  complianceItem   ComplianceItem? @relation(fields: [complianceItemId], references: [id])
  createdAt        DateTime       @default(now())

  @@index([entityId])
  @@index([authorId])
  @@index([entityType])
  @@index([complianceItemId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  message   String
  type      NotificationType @default(system)
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([isRead])
}

model AuditLog {
  id         String      @id @default(cuid())
  action     AuditAction
  entityType String
  entityId   String
  userId     String
  user       User        @relation(fields: [userId], references: [id])
  details    String?
  ipAddress  String?
  createdAt  DateTime    @default(now())

  @@index([userId])
  @@index([entityType])
  @@index([createdAt])
}