generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ComplianceStatus {
  pending
  in_progress
  completed
  overdue
  not_applicable
}

enum Priority {
  low
  medium
  high
  critical
}

enum UserRole {
  admin
  manager
  member
}

model Department {
  id          String           @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  compliance  ComplianceItem[]
  users       User[]
}

model ComplianceItem {
  id             String           @id @default(cuid())
  title          String
  description    String?
  complianceType String
  status         ComplianceStatus @default(pending)
  priority       Priority         @default(medium)
  dueDate        DateTime?
  departmentId   String
  department     Department       @relation(fields: [departmentId], references: [id])
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  }

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  role         UserRole   @default(member)
  avatarUrl    String?
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  auditLogs    AuditLog[]
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  details    String?
  createdAt  DateTime @default(now())
}