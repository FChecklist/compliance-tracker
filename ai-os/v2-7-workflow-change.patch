+      #       && echo "STAGING DATABASE_URL added (staging branch only)" || echo "already exists — skipping"
+      # ------------------------------------------------------------------
+      - name: (V2-7) Staging env-var scoping is configured above
+        run: |
+          echo "Per-env scoping wired (V2-7). Staging-only vars are added under the"
+          echo "'Staging-only vars' block above, scoped via target=[\"preview\"] + gitBranch=\"staging\"."
+          echo "No staging-specific secrets are provisioned yet -- add STAGING_* secrets and"
+          echo "uncomment the corresponding block when a staging-only value is needed."
+          echo "Smoke-test expectation: see ai-os/STAGING_ENV_2026-07-20.md."
